<Page x:Class="Aquila.Views.Pages.ExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Aquila.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:Aquila.Helpers"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Explorer"
      Style="{StaticResource BasePageStyle}">

    <Page.Resources>
        <helpers:HardwareTypeToIconConverter x:Key="HardwareTypeToIconConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,20">
        <ItemsControl ItemsSource="{Binding ViewModel.GroupedHardware}" Margin="20,8,20,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardExpander
                        Margin="0,0,0,4"
                        IsExpanded="False"
                        CornerRadius="8"
                        Icon="{Binding HardwareType, Converter={StaticResource HardwareTypeToIconConverter}}">

                        <!-- Header: Hardware name + sensor count -->
                        <ui:CardExpander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{Binding HardwareName}"
                                        FontSize="14"
                                        FontWeight="SemiBold"/>
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.6"
                                        Margin="0,2,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} sensor groups">
                                                <Binding Path="SensorGroups.Count"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </ui:CardExpander.Header>

                        <!-- Content: sensor groups -->
                        <ItemsControl ItemsSource="{Binding SensorGroups}" Margin="0,8,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,16">

                                        <!-- Category label -->
                                        <TextBlock
                                            Text="{Binding CategoryName}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Opacity="0.55"
                                            Margin="2,0,0,6"/>

                                        <!-- Column headers -->
                                        <Grid Margin="2,0,2,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Sensor" FontSize="11" Opacity="0.5" FontWeight="Medium"/>
                                            <TextBlock Grid.Column="1" Text="Value" FontSize="11" Opacity="0.5" FontWeight="Medium" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="Min" FontSize="11" Opacity="0.5" FontWeight="Medium" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="Max" FontSize="11" Opacity="0.5" FontWeight="Medium" HorizontalAlignment="Right"/>
                                        </Grid>

                                        <!-- Sensor rows -->
                                        <ItemsControl ItemsSource="{Binding Sensors}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid
                                                        Margin="2,0,2,0"
                                                        MinHeight="32">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="80"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            Text="{Binding Name}"
                                                            FontSize="13"
                                                            VerticalAlignment="Center"/>
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                    <Binding Path="Value"/>
                                                                    <Binding Path="Unit"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            FontSize="12"
                                                            Opacity="0.55"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                    <Binding Path="Min"/>
                                                                    <Binding Path="Unit"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock
                                                            Grid.Column="3"
                                                            FontSize="12"
                                                            Opacity="0.55"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                    <Binding Path="Max"/>
                                                                    <Binding Path="Unit"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Page>
