<Page x:Class="Aquila.Views.Pages.StoragePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Aquila.ViewModels.Pages"
      xmlns:helpers="clr-namespace:Aquila.Helpers"
      Style="{StaticResource BasePageStyle}"
      Title="StoragePage"
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:NullToCollapsedConverter  x:Key="NullToCollapsedConverter"/>
        <helpers:ThroughputConverter       x:Key="ThroughputConverter"/>
        <helpers:ThermalBrushConverter     x:Key="ThermalBrushConverter"/>
        <helpers:DataGbConverter           x:Key="DataGbConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Padding="20,12,20,4">
            <StackPanel>
                <TextBlock Text="Storage" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Physical drives · capacity · sensor data"
                           FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Drive list -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding ViewModel.Drives}"
                      Margin="20,4,20,20">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StoragePageDriveItem}">
                    <ui:CardExpander Margin="0,0,0,4" IsExpanded="True" CornerRadius="8">

                        <!-- ── Card header (always visible) ───────────────────── -->
                        <ui:CardExpander.Header>
                            <Grid Margin="0,2,12,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Drive letter badge -->
                                <Border Grid.Column="0"
                                        Background="{DynamicResource Aquila.Ram}"
                                        CornerRadius="6" Width="38" Height="38"
                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriveLetter}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>

                                <!-- Drive name + sub-badges -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                Visibility="{Binding DriveTypeTag, Converter={StaticResource NullToCollapsedConverter}}">
                                            <TextBlock Text="{Binding DriveTypeTag}" FontSize="10" Opacity="0.70"/>
                                        </Border>
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding FileSystem}" FontSize="10" Opacity="0.70"/>
                                        </Border>
                                        <TextBlock Text="{Binding TotalCapacity}"
                                                   FontSize="10" Opacity="0.45"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Current read / write rates -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            Visibility="{Binding LhmName, Converter={StaticResource NullToCollapsedConverter}}">
                                    <TextBlock FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,3">
                                        <Run Text="↓ " Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        <Run Text="{Binding ReadSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" HorizontalAlignment="Right">
                                        <Run Text="↑ " Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        <Run Text="{Binding WriteSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                    </TextBlock>
                                </StackPanel>

                            </Grid>
                        </ui:CardExpander.Header>

                        <!-- ── Expanded body ──────────────────────────────────── -->
                        <StackPanel Margin="50,4,0,4">

                            <!-- Capacity bar -->
                            <ProgressBar Style="{StaticResource RamBar}"
                                         Value="{Binding UsedPercent}"
                                         Margin="0,0,0,6"/>

                            <!-- Used / Total / Free text row -->
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding UsedPercent, StringFormat='{}{0:F0}%'}"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text=" · " FontSize="12" Opacity="0.30"/>
                                    <TextBlock Text="{Binding UsedCapacity}" FontSize="12"/>
                                    <TextBlock Text=" used  /  " FontSize="12" Opacity="0.40"/>
                                    <TextBlock Text="{Binding TotalCapacity}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.50">
                                    <Run Text="{Binding FreeCapacity}"/>
                                    <Run Text=" free"/>
                                </TextBlock>
                            </Grid>

                            <!-- LHM sensor chips — Temp · Data Read · Data Written -->
                            <UniformGrid Columns="3"
                                         Visibility="{Binding LhmName, Converter={StaticResource NullToCollapsedConverter}}">

                                <!-- Temperature -->
                                <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TempSensor.Min, StringFormat='Min: {0:F0} °C', FallbackValue='Min: --'}"/>
                                                <TextBlock Text="{Binding TempSensor.Max, StringFormat='Max: {0:F0} °C', FallbackValue='Max: --'}"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatBoxValue}"
                                                   Foreground="{Binding TempSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                            <Run Text="{Binding TempSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                            <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Total data read -->
                                <Border Style="{StaticResource StatBox}" Margin="3,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DataReadSensor.Min, Converter={StaticResource DataGbConverter}, StringFormat='Min: {0}', FallbackValue='Min: --'}"/>
                                                <TextBlock Text="{Binding DataReadSensor.Max, Converter={StaticResource DataGbConverter}, StringFormat='Max: {0}', FallbackValue='Max: --'}"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatBoxValue}"
                                                   Foreground="{DynamicResource Aquila.Ram}"
                                                   Text="{Binding DataReadSensor.Value, Converter={StaticResource DataGbConverter}, FallbackValue='--'}"/>
                                        <TextBlock Text="Data Read" Style="{StaticResource StatBoxLabel}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Total data written (TBW) -->
                                <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DataWrittenSensor.Min, Converter={StaticResource DataGbConverter}, StringFormat='Min: {0}', FallbackValue='Min: --'}"/>
                                                <TextBlock Text="{Binding DataWrittenSensor.Max, Converter={StaticResource DataGbConverter}, StringFormat='Max: {0}', FallbackValue='Max: --'}"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatBoxValue}"
                                                   Foreground="{DynamicResource Aquila.Ram}"
                                                   Text="{Binding DataWrittenSensor.Value, Converter={StaticResource DataGbConverter}, FallbackValue='--'}"/>
                                        <TextBlock Text="Data Written" Style="{StaticResource StatBoxLabel}"/>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>

                        </StackPanel>

                    </ui:CardExpander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</Page>


