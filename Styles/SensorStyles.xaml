<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:Aquila.Helpers">

    <!-- ════════════════════════════════════════════════════════════════
         Typography — section headers, row labels and values
         ════════════════════════════════════════════════════════════════ -->

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Opacity" Value="0.38"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="ChipName" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="RowLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Opacity" Value="0.50"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="RowValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatBox" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="5,4"/>
    </Style>

    <Style x:Key="StatBoxValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatBoxLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Opacity" Value="0.40"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
    </Style>

    <Style x:Key="Divider" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
        <Setter Property="Opacity" Value="0.14"/>
        <Setter Property="Margin" Value="0,5"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════
         ThinBar — base progress bar template
         ════════════════════════════════════════════════════════════════ -->

    <Style x:Key="ThinBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="3" Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            Height="{TemplateBinding Height}">
                        <Border x:Name="PART_Track" HorizontalAlignment="Left" CornerRadius="3"
                                Background="{TemplateBinding Foreground}">
                            <Border.Width>
                                <MultiBinding>
                                    <MultiBinding.Converter>
                                        <helpers:ProgressBarWidthConverter/>
                                    </MultiBinding.Converter>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════
         Named sensor bars — BasedOn ThinBar, colour from Aquila.* tokens
         ════════════════════════════════════════════════════════════════ -->

    <Style x:Key="CpuBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Cpu}"/>
    </Style>

    <Style x:Key="GpuBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Gpu}"/>
    </Style>

    <Style x:Key="RamBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Ram}"/>
    </Style>

    <Style x:Key="TempBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Temp}"/>
    </Style>

    <Style x:Key="GpuTempBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.GpuTemp}"/>
    </Style>

    <Style x:Key="PowerBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Power}"/>
    </Style>

    <Style x:Key="FanBar" TargetType="ProgressBar" BasedOn="{StaticResource ThinBar}">
        <Setter Property="Foreground" Value="{DynamicResource Aquila.Cpu}"/>
    </Style>

</ResourceDictionary>
