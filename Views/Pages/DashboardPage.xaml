<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Aquila.Controls"
    xmlns:vm="clr-namespace:Aquila.ViewModels.Pages"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
            <Setter Property="VerticalAlignment"        Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>

        <helpers:ThroughputConverter x:Key="ThroughputConverter"/>
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <helpers:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
        <helpers:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
        <helpers:ThermalBrushConverter x:Key="ThermalBrushConverter"/>
        <helpers:WidthThresholdConverter x:Key="WidthThresholdConverter"/>

        <!-- Core bar DataTemplate -->
        <DataTemplate x:Key="CoreBarTemplate" DataType="{x:Type vm:CoreBarItem}">
            <StackPanel>
                <TextBlock Text="{Binding Label}" FontSize="10" Opacity="0.45"
                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4" Height="92" Margin="4,0"
                        HorizontalAlignment="Stretch">
                    <Border VerticalAlignment="Bottom" CornerRadius="4"
                            Background="{DynamicResource Aquila.Cpu}" Opacity="0.85"
                            Height="{Binding BarHeight}"
                            HorizontalAlignment="Stretch"/>
                </Border>
                <TextBlock Text="{Binding ValueText}" FontSize="9" Opacity="0.50"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- GPU card DataTemplate -->
        <DataTemplate x:Key="GpuCardTemplate" DataType="{x:Type vm:GpuCardData}">
            <ui:Card Padding="12,10" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: header + stats + usage label -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="GPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding Name}" Style="{StaticResource ChipName}" Margin="0,0,0,8"/>

                        <UniformGrid Columns="4" Margin="0,0,0,10">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding Load.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding Temperature.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding Temperature.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Gpu}">
                                        <Run Text="{Binding Clock.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Gpu}">
                                        <Run Text="{Binding Power.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,4,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <!-- Row 1: sparkline fills remaining space -->
                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding Load.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.Gpu}"
                        MaxY="100"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>

                    <!-- Row 2: VRAM + fan (hide when narrow) -->
                    <StackPanel Grid.Row="2">
                        <StackPanel Margin="0,4,0,0"
                                    Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                            <TextBlock Text="VRAM" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="20" FontWeight="Normal"
                                           Foreground="{DynamicResource Aquila.Gpu}"
                                           Text="{Binding VramUsed.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                                <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="/ {0:F0} {1}" FallbackValue="/ -- ">
                                            <Binding Path="VramTotal.Value"/>
                                            <Binding Path="VramUsed.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <ProgressBar Style="{StaticResource GpuBar}" Height="8"
                                         Value="{Binding VramUsed.Value, FallbackValue=0}"
                                         Maximum="{Binding VramTotal.Value, FallbackValue=1}"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="10" Opacity="0.40"
                                           Text="{Binding VramUsed.Value, StringFormat='{}{0:F1} used', FallbackValue='used'}"/>
                                <TextBlock Grid.Column="1" FontSize="10" Opacity="0.40">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1} total" FallbackValue="total">
                                            <Binding Path="VramTotal.Value"/>
                                            <Binding Path="VramUsed.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                            <StackPanel Visibility="{Binding Fan1.Value, Converter={StaticResource NullToCollapsedConverter}}">
                                <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        Opacity="0.14" Margin="0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Fan2.Value}" Value="{x:Null}">
                                                        <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                    <Binding Path="Fan1.Value"/>
                                                    <Binding Path="Fan1.Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Visibility="{Binding Fan2.Value, Converter={StaticResource NullToCollapsedConverter}}">
                                        <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                    <Binding Path="Fan2.Value"/>
                                                    <Binding Path="Fan2.Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </DataTemplate>

    </Page.Resources>

    <StackPanel>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="5" Padding="10,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="13" Margin="0,0,5,0" Opacity="0.45"/>
                    <TextBlock Text="{Binding ViewModel.SystemUptime}" FontSize="12" Opacity="0.65"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="5" Padding="10,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="13" Margin="0,0,5,0" Opacity="0.45"/>
                    <TextBlock Text="{Binding ViewModel.CurrentDateTime}" FontSize="12" Opacity="0.65"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <controls:ResponsiveCardPanel Gap="8" MinCardWidth="320">

            <!-- ── CPU card ─────────────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: header + stats + core bars + label -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="CPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Hardware.Cpus[0].Name, FallbackValue='Processor'}"
                                   Style="{StaticResource ChipName}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ViewModel.CpuSummary}"
                                   FontSize="10" Opacity="0.45" Margin="0,0,0,8"
                                   Visibility="{Binding ViewModel.CpuSummary, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <UniformGrid Columns="4" Margin="0,0,0,10">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding ViewModel.Hardware.Cpus[0].Load.Total.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding ViewModel.Hardware.Cpus[0].Temperature.Primary.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding ViewModel.Hardware.Cpus[0].Temperature.Primary.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Cpu}">
                                        <Run Text="{Binding ViewModel.Hardware.Cpus[0].Clock.CoresAverage.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Eff. Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Power}">
                                        <Run Text="{Binding ViewModel.Hardware.Cpus[0].Power.Package.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <StackPanel Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                            <TextBlock Text="CORE LOAD" Style="{StaticResource SectionLabel}"/>
                            <ItemsControl ItemsSource="{Binding ViewModel.CpuCoreItems}"
                                          ItemTemplate="{StaticResource CoreBarTemplate}"
                                          Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <!-- Row 1: sparkline fills remaining space -->
                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.Cpus[0].Load.Total.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.Cpu}"
                        MaxY="100"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>

                    <!-- Row 2: fan section (hide when narrow) -->
                    <StackPanel Grid.Row="2"
                                Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                        <Border Style="{StaticResource Divider}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Visibility="{Binding ViewModel.Hardware.Motherboard.CpuFan, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Text="{Binding ViewModel.Hardware.Motherboard.CpuFan.Name, FallbackValue='CPU Fan'}"
                                           Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuFan.Value"/>
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuFan.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Visibility="{Binding ViewModel.Hardware.Motherboard.CpuFanSecondary, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Text="{Binding ViewModel.Hardware.Motherboard.CpuFanSecondary.Name, FallbackValue='CPU Fan 2'}"
                                           Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuFanSecondary.Value"/>
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuFanSecondary.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Visibility="{Binding ViewModel.Hardware.Motherboard.CpuPump, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Text="{Binding ViewModel.Hardware.Motherboard.CpuPump.Name, FallbackValue='Pump'}"
                                           Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuPump.Value"/>
                                            <Binding Path="ViewModel.Hardware.Motherboard.CpuPump.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── GPU cards ─────────────────────────────────────────── -->
            <ContentControl Content="{Binding ViewModel.Gpu1}"
                            ContentTemplate="{StaticResource GpuCardTemplate}"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Visibility="{Binding ViewModel.Gpu1, Converter={StaticResource NullToCollapsedConverter}}"/>
            <ContentControl Content="{Binding ViewModel.Gpu2}"
                            ContentTemplate="{StaticResource GpuCardTemplate}"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Visibility="{Binding ViewModel.Gpu2, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- ── RAM card ──────────────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: header + bar + legend + label -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="RAM" Style="{StaticResource SectionLabel}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock FontSize="26" FontWeight="Light"
                                       Text="{Binding ViewModel.Hardware.Memory.Data.Used.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                            <TextBlock Text="GB" FontSize="12" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="2,0,0,4"/>
                        </StackPanel>

                        <TextBlock FontSize="12" Opacity="0.60" Margin="0,0,0,2"
                                   Text="{Binding ViewModel.Hardware.Memory.Data.Total.Value, StringFormat='de {0:F0} GB total', FallbackValue='--'}"/>

                        <Grid Height="8" Margin="0,6,0,4" x:Name="MemBar" ClipToBounds="True">
                            <Border CornerRadius="4" Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Background="{DynamicResource Aquila.Cpu}" CornerRadius="4,0,0,4">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.MemPhysUsedFrac"/>
                                            <Binding Source="0"/>
                                            <Binding Source="1"/>
                                            <Binding ElementName="MemBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <Border DockPanel.Dock="Left" Background="{DynamicResource Aquila.Cpu}" Opacity="0.18">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.MemPhysFreeFrac"/>
                                            <Binding Source="0"/>
                                            <Binding Source="1"/>
                                            <Binding ElementName="MemBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <Border DockPanel.Dock="Left" Background="{DynamicResource Aquila.Ram}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.MemVirtUsedFrac"/>
                                            <Binding Source="0"/>
                                            <Binding Source="1"/>
                                            <Binding ElementName="MemBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <Border Background="{DynamicResource Aquila.Ram}" Opacity="0.18" CornerRadius="0,4,4,0"/>
                            </DockPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,3">
                                    <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Background="{DynamicResource Aquila.Cpu}"/>
                                    <TextBlock FontSize="11" Opacity="0.65"
                                               Text="{Binding ViewModel.Hardware.Memory.Data.Used.Value, StringFormat='Física {0:F1} usada', FallbackValue='--'}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,3">
                                    <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Background="{DynamicResource Aquila.Ram}"/>
                                    <TextBlock FontSize="11" Opacity="0.65"
                                               Text="{Binding ViewModel.Hardware.Memory.Virtual.Used.Value, StringFormat='Virtual {0:F1} usada', FallbackValue='--'}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Background="{DynamicResource Aquila.Cpu}" Opacity="0.35"/>
                                    <TextBlock FontSize="11" Opacity="0.65"
                                               Text="{Binding ViewModel.Hardware.Memory.Data.Available.Value, StringFormat='Física {0:F1} livre', FallbackValue='--'}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Background="{DynamicResource Aquila.Ram}" Opacity="0.35"/>
                                    <TextBlock FontSize="11" Opacity="0.65"
                                               Text="{Binding ViewModel.Hardware.Memory.Virtual.Available.Value, StringFormat='Virtual {0:F1} livre', FallbackValue='--'}"/>
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource Divider}"/>
                        </StackPanel>

                        <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <!-- Row 1: sparkline fills remaining space -->
                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.Memory.Load.Total.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.Ram}"
                        MaxY="100"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>

                    <!-- Row 2: DIMMs (hide when narrow) -->
                    <StackPanel Grid.Row="2"
                                Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                        <StackPanel Visibility="{Binding ViewModel.Hardware.Memory.Dimms.Count, Converter={StaticResource ZeroToCollapsedConverter}}">
                            <Border Style="{StaticResource Divider}"/>
                            <TextBlock Text="DIMMS" Style="{StaticResource SectionLabel}"/>
                            <ItemsControl ItemsSource="{Binding ViewModel.Hardware.Memory.Dimms}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                               Foreground="{Binding Temperature.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                                                <Binding Path="Temperature.Value"/>
                                                                <Binding Path="Temperature.Unit"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10" Opacity="0.55" HorizontalAlignment="Right"
                                                               Visibility="{Binding WarningTemperature.Value, Converter={StaticResource NullToCollapsedConverter}}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="warn {0:F0}°C • crit {1:F0}°C" FallbackValue="warn -- • crit --">
                                                                <Binding Path="WarningTemperature.Value"/>
                                                                <Binding Path="CriticalTemperature.Value"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── Network card ──────────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: header + throughput rows -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="NETWORK" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Hardware.Networks[0].Name, FallbackValue='Adapter'}"
                                   FontSize="12" FontWeight="Normal" Opacity="0.55"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↓ Download" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Cpu}"
                                       Text="{Binding ViewModel.Hardware.Networks[0].Throughput.Download.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↑ Upload" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Ram}"
                                       Text="{Binding ViewModel.Hardware.Networks[0].Throughput.Upload.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <TextBlock Text="THROUGHPUT ° 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <!-- Row 1: sparkline fills remaining space -->
                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.Networks[0].Throughput.Download.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.NetDown}"
                        SecondValues="{Binding ViewModel.Hardware.Networks[0].Throughput.Upload.History}"
                        SecondColor="{DynamicResource Aquila.Chart.NetUp}"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>

                    <!-- Row 2: totals (hide when narrow) -->
                    <StackPanel Grid.Row="2"
                                Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=260}">
                        <Border Style="{StaticResource Divider}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Received" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Hardware.Networks[0].Data.Downloaded.Value"/>
                                        <Binding Path="ViewModel.Hardware.Networks[0].Data.Downloaded.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sent" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Hardware.Networks[0].Data.Uploaded.Value"/>
                                        <Binding Path="ViewModel.Hardware.Networks[0].Data.Uploaded.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── Storage card ──────────────────────────────────────── -->
            <ui:Card Padding="12,10"
                     Visibility="{Binding ViewModel.Hardware.Storages.Count, Converter={StaticResource ZeroToCollapsedConverter}}">
                <StackPanel>
                    <TextBlock Text="STORAGE" Style="{StaticResource SectionLabel}"/>
                    <ItemsControl ItemsSource="{Binding ViewModel.Hardware.Storages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource ChipName}" Margin="0,4,0,10"
                                               TextTrimming="CharacterEllipsis"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource StatBoxValue}"
                                                           Foreground="{Binding Temperature.Primary.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                    <Run Text="{Binding Temperature.Primary.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                    <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource StatBoxValue}">
                                                    <Run Text="{Binding Load.UsedSpace.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                    <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="Used" Style="{StaticResource StatBoxLabel}"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Read" Style="{StaticResource RowLabel}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Aquila.Cpu}"
                                                   Text="{Binding Throughput.ReadRate.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                    </Grid>
                                    <ProgressBar Style="{StaticResource CpuBar}" Margin="0,2,0,6"
                                                 Value="{Binding Throughput.ReadRate.Value, FallbackValue=0}"
                                                 Maximum="{Binding Throughput.ReadRate.Max, FallbackValue=1}"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Write" Style="{StaticResource RowLabel}"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Aquila.Ram}"
                                                   Text="{Binding Throughput.WriteRate.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                    </Grid>
                                    <ProgressBar Style="{StaticResource RamBar}" Margin="0,2,0,0"
                                                 Value="{Binding Throughput.WriteRate.Value, FallbackValue=0}"
                                                 Maximum="{Binding Throughput.WriteRate.Max, FallbackValue=1}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <!-- ── Temperatures card ─────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="TEMPERATURES" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.Hardware.Motherboard.Temperature}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatBox}" Margin="0,0,6,6">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatBoxValue}"
                                                       Foreground="{Binding Value, Converter={StaticResource ThermalBrushConverter}}">
                                                <Run Text="{Binding Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                <Run Text="°C" FontSize="14" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource StatBoxLabel}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="CPU DIE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,4,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.Cpus[0].Temperature.Primary.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.Cpu}"
                        MaxY="100"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                </Grid>
            </ui:Card>

            <!-- ── Fans card ─────────────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="FANS" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.Hardware.Motherboard.Fan}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding Value, Converter={StaticResource ZeroToCollapsedConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Style="{StaticResource RowLabel}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Grid.Column="1"
                                                     Style="{StaticResource FanBar}"
                                                     VerticalAlignment="Center"
                                                     Value="{Binding Value, FallbackValue=0}"
                                                     Maximum="{Binding Max, FallbackValue=3000}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12" HorizontalAlignment="Right">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                    <Binding Path="Value"/>
                                                    <Binding Path="Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="CPU FAN ° 60s" Style="{StaticResource SectionLabel}" Margin="0,4,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.Motherboard.CpuFan.History}"
                        SeriesColor="{DynamicResource Aquila.Chart.NetDown}"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                </Grid>
            </ui:Card>

            <!-- ── Power card ────────────────────────────────────────── -->
            <ui:Card Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="POWER" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontSize="26"
                                       Text="{Binding ViewModel.Hardware.TotalPower.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                            <TextBlock Text="W total" FontSize="12" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="5,0,0,4"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource CpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Hardware.Cpus[0].Power.Package.Value, FallbackValue=0}"
                                         Maximum="{Binding ViewModel.Hardware.Cpus[0].Power.Package.Max, FallbackValue=1}"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Hardware.Cpus[0].Power.Package.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource GpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Gpu1.Power.Value, FallbackValue=0}"
                                         Maximum="{Binding ViewModel.Gpu1.Power.Max, FallbackValue=1}"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Gpu1.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"
                              Visibility="{Binding ViewModel.Gpu2, Converter={StaticResource NullToCollapsedConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU 2" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource GpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Gpu2.Power.Value, FallbackValue=0}"
                                         Maximum="{Binding ViewModel.Gpu2.Power.Max, FallbackValue=1}"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Gpu2.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <TextBlock Text="TOTAL ° 60s" Style="{StaticResource SectionLabel}" Margin="0,4,0,2"
                                   Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                    </StackPanel>

                    <controls:SparklineChart Grid.Row="1" MinHeight="40"
                        Values="{Binding ViewModel.Hardware.TotalPower.History}"
                        SeriesColor="{DynamicResource Aquila.Power}"
                        Visibility="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ui:Card}}, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=280}"/>
                </Grid>
            </ui:Card>

        </controls:ResponsiveCardPanel>

    </StackPanel>

</Page>
