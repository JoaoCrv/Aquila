<Page x:Class="Aquila.Views.Pages.ExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Aquila.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:Aquila.Helpers"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Explorer"
      Style="{StaticResource BasePageStyle}">

    <Page.Resources>
        <helpers:HardwareTypeToIconConverter x:Key="HardwareTypeToIconConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15,10,15,15">
        <ItemsControl ItemsSource="{Binding ViewModel.GroupedHardware}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardExpander
                        Margin="0,0,0,8"
                        IsExpanded="True"
                        Icon="{Binding HardwareType, Converter={StaticResource HardwareTypeToIconConverter}}"
                        Header="{Binding HardwareName}">
                        <ItemsControl ItemsSource="{Binding SensorGroups}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock
                                            Text="{Binding CategoryName}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Opacity="0.6"
                                            Margin="4,0,0,4"/>
                                        <ui:ListView
                                            ItemsSource="{Binding Sensors}"
                                            Background="Transparent"
                                            BorderThickness="0">
                                            <ui:ListView.View>
                                                <ui:GridView>
                                                    <ui:GridViewColumn Header="Sensor" DisplayMemberBinding="{Binding Name}" Width="220"/>
                                                    <ui:GridViewColumn Header="Value" Width="110">
                                                        <ui:GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                            <Binding Path="Value"/>
                                                                            <Binding Path="Unit"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ui:GridViewColumn.CellTemplate>
                                                    </ui:GridViewColumn>
                                                    <ui:GridViewColumn Header="Min" Width="80">
                                                        <ui:GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock HorizontalAlignment="Right" Opacity="0.6">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                            <Binding Path="Min"/>
                                                                            <Binding Path="Unit"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ui:GridViewColumn.CellTemplate>
                                                    </ui:GridViewColumn>
                                                    <ui:GridViewColumn Header="Max" Width="80">
                                                        <ui:GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock HorizontalAlignment="Right" Opacity="0.6">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                            <Binding Path="Max"/>
                                                                            <Binding Path="Unit"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ui:GridViewColumn.CellTemplate>
                                                    </ui:GridViewColumn>
                                                    <ui:GridViewColumn Header="Identifier" DisplayMemberBinding="{Binding Identifier}" Width="300"/>
                                                </ui:GridView>
                                            </ui:ListView.View>
                                        </ui:ListView>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Page>
