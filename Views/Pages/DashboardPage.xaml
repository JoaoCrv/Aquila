<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Aquila.Controls"
    xmlns:vm="clr-namespace:Aquila.ViewModels.Pages"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    mc:Ignorable="d">

    <Page.Resources>

        <helpers:ThroughputConverter x:Key="ThroughputConverter"/>
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <helpers:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
        <helpers:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
        <helpers:ThermalBrushConverter x:Key="ThermalBrushConverter"/>
        <helpers:FanMaxConverter x:Key="FanMaxConverter"/>
        <helpers:ColumnWidthConverter x:Key="ColumnWidthConverter"/>
        <helpers:ResponsivePaddingConverter x:Key="ResponsivePaddingConverter"/>

        <!-- Core bar DataTemplate -->
        <DataTemplate x:Key="CoreBarTemplate" DataType="{x:Type vm:CoreBarItem}">
            <StackPanel Margin="0,0">
                <TextBlock Text="{Binding Label}" FontSize="10" Opacity="0.45"
                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4" Height="92" Margin="4,0"
                        HorizontalAlignment="Stretch">
                    <Border VerticalAlignment="Bottom" CornerRadius="4"
                            Background="{DynamicResource Aquila.Cpu}" Opacity="0.85"
                            Height="{Binding BarHeight}"
                            HorizontalAlignment="Stretch"/>
                </Border>
                <TextBlock Text="{Binding ValueText}" FontSize="9" Opacity="0.50"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- GPU card DataTemplate (GPU1 and GPU2 share this) -->
        <DataTemplate x:Key="GpuCardTemplate" DataType="{x:Type vm:GpuCardData}">
            <ui:Card Margin="0,0,0,8" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="GPU" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource ChipName}" Margin="0,0,0,8"/>

                    <!-- 4 stat boxes -->
                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}">
                                    <Run Text="{Binding Load.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{Binding Temperature.Value, Converter={StaticResource ThermalBrushConverter}}">
                                    <Run Text="{Binding Temperature.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{DynamicResource Aquila.Gpu}">
                                    <Run Text="{Binding Clock.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Clock" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{DynamicResource Aquila.Power}">
                                            <Run Text="{Binding Power.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                    <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <!-- GPU usage sparkline -->
                                    <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,4,0,2"/>
                                    <controls:SparklineChart
                                        Height="52"
                                        Values="{Binding UsageHistory}"
                                        SeriesColor="{DynamicResource Aquila.Chart.Gpu}"
                                        MaxY="100"/>

                                    <!-- VRAM -->
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock Text="VRAM" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontSize="20" FontWeight="Normal"
                                       Foreground="{DynamicResource Aquila.Gpu}"
                                       Text="{Binding VramUsed.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                            <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="/ {0:F0} {1}" FallbackValue="/ -- ">
                                        <Binding Path="VramTotal.Value"/>
                                        <Binding Path="VramUsed.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <ProgressBar Style="{StaticResource GpuBar}" Height="8"
                                     Value="{Binding VramPercent, Mode=OneWay, FallbackValue=0}"
                                     Maximum="100"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="10" Opacity="0.40"
                                       Text="{Binding VramUsed.Value, StringFormat='{}{0:F1} used', FallbackValue='used'}"/>
                            <TextBlock Grid.Column="1" FontSize="10" Opacity="0.40">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1} total" FallbackValue="total">
                                        <Binding Path="VramTotal.Value"/>
                                        <Binding Path="VramUsed.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Opacity="0.14" Margin="0,8"/>

                    <!-- Fans -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                        <Binding Path="Fan1.Value"/>
                                        <Binding Path="Fan1.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                        <Binding Path="Fan2.Value"/>
                                        <Binding Path="Fan2.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </DataTemplate>

    </Page.Resources>


    <StackPanel x:Name="DashboardRoot">

        <!-- Header: uptime + date/time = -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="5" Padding="10,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="13" Margin="0,0,5,0" Opacity="0.45"/>
                    <TextBlock Text="{Binding ViewModel.SystemUptime}" FontSize="12" Opacity="0.65"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="5" Padding="10,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="13" Margin="0,0,5,0" Opacity="0.45"/>
                    <TextBlock Text="{Binding ViewModel.CurrentDateTime}" FontSize="12" Opacity="0.65"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- =
                 RESPONSIVE CARD COLUMNS (2 ? 1 at 580 px breakpoint)
                 Col 0 ° CPU + GPU(s)
                 Col 1 ° RAM + Network + Storage + Power + Temperatures + Fans
                 = -->
        <WrapPanel>

            <!-- =
                 COL 0 ° CPU card  +  GPU card(s) below
                 = -->
            <StackPanel Margin="0,0,8,8"
                        Width="{Binding ActualWidth, ElementName=DashboardRoot, Converter={StaticResource ColumnWidthConverter}}">

                <!-- CPU card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Aquila.Cpu.Name, FallbackValue='Processor'}"
                                   Style="{StaticResource ChipName}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ViewModel.Aquila.Cpu.Summary}"
                                   FontSize="10" Opacity="0.45" Margin="0,0,0,8"
                                   Visibility="{Binding ViewModel.Aquila.Cpu.Summary, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <!-- 4 stat boxes -->
                        <UniformGrid Columns="4" Margin="0,0,0,10">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding ViewModel.CpuGaugeValue, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding ViewModel.Aquila.Cpu.Temperature.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding ViewModel.Aquila.Cpu.Temperature.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Cpu}">
                                        <Run Text="{Binding ViewModel.EffectiveCpuClock, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Eff. Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Power}">
                                        <Run Text="{Binding ViewModel.Aquila.Cpu.Power.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Per-core bar chart ° WrapPanel fills available width -->
                        <TextBlock Text="CORE LOAD" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.CpuCoreItems}"
                                      ItemTemplate="{StaticResource CoreBarTemplate}"
                                      Margin="0,0,0,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- CPU sparkline -->
                        <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                        <controls:SparklineChart
                            Height="52"
                            Values="{Binding ViewModel.CpuUsageHistory}"
                            SeriesColor="{DynamicResource Aquila.Chart.Cpu}"
                            MaxY="100"/>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- CPU fans -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Aquila.Cpu.FanRpm.Value"/>
                                            <Binding Path="ViewModel.Aquila.Cpu.FanRpm.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Aquila.Cpu.Fan2Rpm.Value"/>
                                            <Binding Path="ViewModel.Aquila.Cpu.Fan2Rpm.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- GPU cards -->
                <ItemsControl ItemsSource="{Binding ViewModel.GpuCards}"
                              ItemTemplate="{StaticResource GpuCardTemplate}"/>

            </StackPanel>

            <!-- =
                 COL 1 ° RAM + Network + Storage + Power + Temperatures + Fans
                 = -->
            <StackPanel Margin="0,0,8,8"
                        Width="{Binding ActualWidth, ElementName=DashboardRoot, Converter={StaticResource ColumnWidthConverter}}">

                <!-- RAM card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource SectionLabel}"/>

                        <!-- Big used value -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock FontSize="26" FontWeight="Light"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="{Binding ViewModel.Aquila.Memory.UsedGb.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                            <TextBlock Text="GB" FontSize="12" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="2,0,0,4"/>
                        </StackPanel>

                        <!-- de X GB -->
                        <TextBlock FontSize="12" Opacity="0.60" Margin="0,0,0,6">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="de {0:F0} GB total" FallbackValue="--">
                                    <Binding Path="ViewModel.Aquila.Memory.TotalVisibleGb"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Segmented bar: Used / Cache / Free -->
                        <Grid Height="8" Margin="0,6,0,4" x:Name="RamBar">
                            <Border CornerRadius="4" Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            <DockPanel>
                                <!-- Used (blue) -->
                                <Border DockPanel.Dock="Left"
                                        Background="{DynamicResource Aquila.Cpu}"
                                        CornerRadius="4,0,0,4">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.RamGaugeValue"/>
                                            <Binding Source="0"/>
                                            <Binding Source="100"/>
                                            <Binding ElementName="RamBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <!-- Cache (green) -->
                                <Border DockPanel.Dock="Left"
                                        Background="{DynamicResource Aquila.Ram}"
                                        Opacity="0.8">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.CacheBarWeight"/>
                                            <Binding Source="0"/>
                                            <Binding Source="100"/>
                                            <Binding ElementName="RamBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <!-- Gap for free space -->
                            </DockPanel>
                        </Grid>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <!-- Used -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource Aquila.Cpu}"/>
                            <TextBlock FontSize="11" Opacity="0.65" Margin="0,0,12,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Usada {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Aquila.Memory.UsedGb.Value"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Cache -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource Aquila.Ram}"/>
                            <TextBlock FontSize="11" Opacity="0.65" Margin="0,0,12,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Cache {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Aquila.Memory.CacheGb"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Free -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource TextFillColorTertiaryBrush}" Opacity="0.3"/>
                            <TextBlock FontSize="11" Opacity="0.65">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Livre {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Aquila.Memory.AvailableGb.Value"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- RAM usage sparkline -->
                        <TextBlock Text="USAGE ° 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                        <controls:SparklineChart
                            Height="52"
                            Values="{Binding ViewModel.RamUsageHistory}"
                            SeriesColor="{DynamicResource Aquila.Chart.Ram}"
                            MaxY="100"/>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- Page reads / writes StatBoxes -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Leitura -->
                            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Page Reads" FontSize="10" Opacity="0.55" Margin="0,0,0,3"/>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Aquila.Cpu}">
                                        <Run Text="{Binding ViewModel.Aquila.Memory.PageReadsPerSec.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="/s" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Escrita -->
                            <Border Grid.Column="1" Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="6" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Page Writes" FontSize="10" Opacity="0.55" Margin="0,0,0,3"/>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Aquila.Ram}">
                                        <Run Text="{Binding ViewModel.Aquila.Memory.PageWritesPerSec.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="/s" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Network card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="NETWORK" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Aquila.Network.Name, FallbackValue='Adapter'}"
                                   FontSize="12" FontWeight="Normal" Opacity="0.55"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↓ Download" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Cpu}"
                                       Text="{Binding ViewModel.Aquila.Network.DownloadSpeed.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↑ Upload" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Ram}"
                                       Text="{Binding ViewModel.Aquila.Network.UploadSpeed.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <controls:SparklineChart
                            Height="52"
                            Margin="0,6,0,0"
                            Values="{Binding ViewModel.NetworkDownloadHistory}"
                            SeriesColor="{DynamicResource Aquila.Chart.NetDown}"
                            SecondValues="{Binding ViewModel.NetworkUploadHistory}"
                            SecondColor="{DynamicResource Aquila.Chart.NetUp}"/>

                        <Border Style="{StaticResource Divider}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Received" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Aquila.Network.DataDownloaded.Value"/>
                                        <Binding Path="ViewModel.Aquila.Network.DataDownloaded.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sent" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.Aquila.Network.DataUploaded.Value"/>
                                        <Binding Path="ViewModel.Aquila.Network.DataUploaded.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Storage card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10"
                         Visibility="{Binding ViewModel.StorageCards.Count, Converter={StaticResource ZeroToCollapsedConverter}}">
                    <StackPanel>
                        <TextBlock Text="STORAGE" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.StorageCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource ChipName}" Margin="0,4,0,10"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <UniformGrid Columns="2" Margin="0,0,0,10">
                                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                                               Foreground="{Binding Temperature.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                        <Run Text="{Binding Temperature.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                                        <Run Text="{Binding UsedSpace.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="Used" Style="{StaticResource StatBoxLabel}"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="? Read" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Aquila.Cpu}"
                                                       Text="{Binding ReadRate.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource CpuBar}" Margin="0,2,0,6"
                                                     Value="{Binding ReadRate.Value, FallbackValue=0}"
                                                     Maximum="600000000"/>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="? Write" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Aquila.Ram}"
                                                       Text="{Binding WriteRate.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource RamBar}" Margin="0,2,0,0"
                                                     Value="{Binding WriteRate.Value, FallbackValue=0}"
                                                     Maximum="600000000"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Temperatures + Fans + Power = -->
                <!-- Temperatures card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="TEMPERATURES" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.SystemTemperatures}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatBox}" Margin="0,0,6,6">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatBoxValue}"
                                                       Foreground="{Binding Metric.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                <Run Text="{Binding Metric.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                <Run Text="°C" FontSize="14" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource StatBoxLabel}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Fans card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="FANS" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.SystemFans}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding Metric.Value, Converter={StaticResource ZeroToCollapsedConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Style="{StaticResource RowLabel}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Grid.Column="1" Style="{StaticResource FanBar}"
                                                     VerticalAlignment="Center"
                                                     Value="{Binding Metric.Value, FallbackValue=0}"
                                                     Maximum="{Binding Metric.Max, Converter={StaticResource FanMaxConverter}}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                    <Binding Path="Metric.Value"/>
                                                    <Binding Path="Metric.Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Power card -->
                <ui:Card Margin="0,0,0,8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="POWER" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontSize="26"
                                       Text="{Binding ViewModel.Aquila.Power.Total.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                            <TextBlock Text="W total" FontSize="12" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="5,0,0,4"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource CpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Aquila.Cpu.Power.Value, FallbackValue=0}"
                                         Maximum="250"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Aquila.Cpu.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource GpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Gpu1.Power.Value, FallbackValue=0}"
                                         Maximum="450"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Gpu1.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5"
                              Visibility="{Binding ViewModel.Gpu2, Converter={StaticResource NullToCollapsedConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU 2" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource GpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Gpu2.Power.Value, FallbackValue=0}"
                                         Maximum="450"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Gpu2.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RAM" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource RamBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Aquila.Memory.Power.Value, FallbackValue=0}"
                                         Maximum="30"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Aquila.Memory.Power.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </WrapPanel>

    </StackPanel>

</Page>
