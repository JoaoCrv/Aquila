<Page
    x:Class="Aquila.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DataContext="{d:DesignInstance local:SettingsPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    Style="{StaticResource BasePageStyle}">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <StackPanel>
        <TextBlock
            FontSize="20"
            FontWeight="Medium"
            Text="Personalization" />
        <TextBlock Margin="0,12,0,0" Text="Theme" />
        <RadioButton
            Margin="0,12,0,0"
            Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
            CommandParameter="theme_light"
            Content="Light"
            GroupName="themeSelect"
            IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}" />
        <RadioButton
            Margin="0,8,0,0"
            Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
            CommandParameter="theme_dark"
            Content="Dark"
            GroupName="themeSelect"
            IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}" />

        <TextBlock Margin="0,20,0,0" Text="Polling interval" />
        <ComboBox Margin="0,8,0,0"
                  ItemsSource="{Binding ViewModel.PollingIntervalOptions}"
                  SelectedItem="{Binding ViewModel.SelectedPollingInterval}"
                  DisplayMemberPath="Label"
                  MinWidth="120"
                  HorizontalAlignment="Left"/>

        <TextBlock Margin="0,24,0,0" FontSize="20" FontWeight="Medium" Text="Behaviour" />

        <ui:ToggleSwitch
            Margin="0,12,0,0"
            Content="Minimize to tray"
            IsChecked="{Binding ViewModel.MinimizeToTray}"
            IsEnabled="{Binding ViewModel.IsNotDashboardMode}" />

        <ui:ToggleSwitch
            Margin="0,8,0,0"
            Content="Start minimized"
            IsChecked="{Binding ViewModel.StartMinimized}"
            IsEnabled="{Binding ViewModel.IsNotDashboardMode}" />

        <ui:ToggleSwitch
            Margin="0,8,0,0"
            Content="Start with Windows"
            IsChecked="{Binding ViewModel.StartWithWindows}"
            IsEnabled="{Binding ViewModel.IsNotDashboardMode}" />

        <ui:ToggleSwitch
            Margin="0,8,0,0"
            Content="Dashboard mode"
            IsChecked="{Binding ViewModel.DashboardMode}" />
        <TextBlock
            Margin="0,4,0,0"
            Opacity="0.55"
            FontSize="12"
            Text="Window opens at the tray icon only, no taskbar entry. Single click to show/hide."
            TextWrapping="Wrap" />

        <TextBlock Margin="0,24,0,0" FontSize="20" FontWeight="Medium" Text="Dashboard cards" />
        <TextBlock Margin="0,4,0,8" Opacity="0.55" FontSize="12"
                   Text="Hidden cards are excluded from the layout entirely." />

        <ui:ToggleSwitch Content="CPU" IsChecked="{Binding ViewModel.ShowCpuCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Memory" IsChecked="{Binding ViewModel.ShowMemoryCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="GPU" IsChecked="{Binding ViewModel.ShowGpuCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Network" IsChecked="{Binding ViewModel.ShowNetworkCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Storage" IsChecked="{Binding ViewModel.ShowStorageCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Temperatures" IsChecked="{Binding ViewModel.ShowTemperaturesCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Power" IsChecked="{Binding ViewModel.ShowPowerCard}" />
        <ui:ToggleSwitch Margin="0,4,0,0" Content="Fans" IsChecked="{Binding ViewModel.ShowFansCard}" />

        <ui:Card Margin="0,24,0,0" Padding="16,14">
            <StackPanel>
                <TextBlock Text="Diagnostics" Style="{StaticResource SectionLabel}" />
                <ui:ToggleSwitch
                    Margin="0,8,0,0"
                    Content="Verbose logging"
                    IsChecked="{Binding ViewModel.EnableVerboseLogging}" />
                <TextBlock
                    Margin="0,4,0,0"
                    Opacity="0.55"
                    FontSize="12"
                    Text="Writes detailed logs to Documents\Aquila\logs\. Useful for troubleshooting. Disabled by default."
                    TextWrapping="Wrap" />
            </StackPanel>
        </ui:Card>

        <ui:Card Margin="0,12,0,0" Padding="16,14">
            <StackPanel>
                <TextBlock Text="Updates" Style="{StaticResource SectionLabel}" />
                <TextBlock Text="{Binding ViewModel.AppVersion, Mode=OneWay}"
                           Style="{StaticResource ChipName}"
                           Margin="0,0,0,6" />
                <TextBlock Margin="0,0,0,8"
                           Opacity="0.60"
                           Text="Aquila can check silently on startup and will notify you before any download or restart."
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,0,0,12"
                           Opacity="0.80"
                           Text="{Binding ViewModel.UpdateStatusMessage, Mode=OneWay}"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ViewModel.CheckForUpdatesCommand, Mode=OneWay}"
                            Content="Check for Updates"
                            Padding="12,6" />
                    <ui:ProgressRing Width="18"
                                     Height="18"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding ViewModel.IsCheckingForUpdates, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </StackPanel>
</Page>
