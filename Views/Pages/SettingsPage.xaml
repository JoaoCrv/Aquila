<Page
    x:Class="Aquila.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DataContext="{d:DesignInstance local:SettingsPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    Style="{StaticResource BasePageStyle}">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <StackPanel>
        <TextBlock
            FontSize="20"
            FontWeight="Medium"
            Text="Personalization" />
        <TextBlock Margin="0,12,0,0" Text="Theme" />
        <RadioButton
            Margin="0,12,0,0"
            Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
            CommandParameter="theme_light"
            Content="Light"
            GroupName="themeSelect"
            IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}" />
        <RadioButton
            Margin="0,8,0,0"
            Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
            CommandParameter="theme_dark"
            Content="Dark"
            GroupName="themeSelect"
            IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}" />

        <ui:Card Margin="0,24,0,0" Padding="16,14">
            <StackPanel>
                <TextBlock Text="Updates" Style="{StaticResource SectionLabel}" />
                <TextBlock Text="{Binding ViewModel.AppVersion, Mode=OneWay}"
                           Style="{StaticResource ChipName}"
                           Margin="0,0,0,6" />
                <TextBlock Margin="0,0,0,8"
                           Opacity="0.60"
                           Text="Aquila can check silently on startup and will notify you before any download or restart."
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,0,0,12"
                           Opacity="0.80"
                           Text="{Binding ViewModel.UpdateStatusMessage, Mode=OneWay}"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ViewModel.CheckForUpdatesCommand, Mode=OneWay}"
                            Content="Check for Updates"
                            Padding="12,6" />
                    <ui:ProgressRing Width="18"
                                     Height="18"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding ViewModel.IsCheckingForUpdates, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </StackPanel>
</Page>
