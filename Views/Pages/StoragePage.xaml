<Page x:Class="Aquila.Views.Pages.StoragePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Aquila.ViewModels.Pages"
      xmlns:helpers="clr-namespace:Aquila.Helpers"
      Style="{StaticResource BasePageStyle}"
      Title="StoragePage"
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:NullToCollapsedConverter  x:Key="NullToCollapsedConverter"/>
        <helpers:ThroughputConverter       x:Key="ThroughputConverter"/>
        <helpers:ThermalBrushConverter     x:Key="ThermalBrushConverter"/>
    </Page.Resources>

    <StackPanel Margin="24,20">

        <TextBlock Text="STORAGE" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>

        <ItemsControl ItemsSource="{Binding ViewModel.Drives}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StoragePageDriveItem}">
                    <ui:Card Margin="0,0,0,8" Padding="16,14">
                        <StackPanel>

                            <!-- Drive letter + label + type + filesystem badges -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="{DynamicResource Aquila.Ram}"
                                        CornerRadius="4" Padding="7,3" Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriveLetter}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" Style="{StaticResource ChipName}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding DriveTypeTag, Converter={StaticResource NullToCollapsedConverter}}">
                                    <TextBlock Text="{Binding DriveTypeTag}"
                                               FontSize="11" Opacity="0.70"/>
                                </Border>
                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileSystem}"
                                               FontSize="11" Opacity="0.70"/>
                                </Border>
                            </StackPanel>

                            <!-- Capacity bar -->
                            <ProgressBar Style="{StaticResource RamBar}"
                                         Value="{Binding UsedPercent}"
                                         Margin="0,0,0,6"/>

                            <!-- Used / Total / Free -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding UsedCapacity}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text=" used" FontSize="12" Opacity="0.50"/>
                                    <TextBlock Text=" / " FontSize="12" Opacity="0.30"/>
                                    <TextBlock Text="{Binding TotalCapacity}" FontSize="12" Opacity="0.60"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding FreeCapacity}" FontSize="12" Opacity="0.50"/>
                                    <TextBlock Text=" free" FontSize="12" Opacity="0.50"/>
                                </StackPanel>
                            </Grid>

                            <!-- LHM sensor section — only visible when drive is detected by LHM -->
                            <StackPanel Visibility="{Binding LhmName, Converter={StaticResource NullToCollapsedConverter}}">
                                <Border Style="{StaticResource Divider}"/>
                                <TextBlock Text="{Binding LhmName}" Style="{StaticResource SectionLabel}"
                                           Margin="0,0,0,8"/>
                                <UniformGrid Columns="3">
                                    <!-- Temperature -->
                                    <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatBoxValue}"
                                                       Foreground="{Binding TempSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                <Run Text="{Binding TempSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                                <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Read rate -->
                                    <Border Style="{StaticResource StatBox}" Margin="3,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatBoxValue}"
                                                       Foreground="{DynamicResource Aquila.Ram}"
                                                       Text="{Binding ReadSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                            <TextBlock Text="↓ Read" Style="{StaticResource StatBoxLabel}"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Write rate -->
                                    <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatBoxValue}"
                                                       Foreground="{DynamicResource Aquila.Ram}"
                                                       Text="{Binding WriteSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                                            <TextBlock Text="↑ Write" Style="{StaticResource StatBoxLabel}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>

                        </StackPanel>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</Page>

