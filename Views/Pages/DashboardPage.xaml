<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <WrapPanel Margin="15">
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU" FontSize="16" FontWeight="SemiBold" Margin="12" />
                <StackPanel Margin="12,-6,12,12" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Temperature24" FontSize="24" Margin="0,0,0,5"/>
                    <TextBlock  HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}">
                                <Binding Path="ViewModel.CPU.Sensors[0].Value" FallbackValue="--"/>
                                <Binding Path="ViewModel.CPU.Sensors[0].Unit" FallbackValue="--"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="{Binding ViewModel.CPU.Sensors[0].Name}" 
                               HorizontalAlignment="Center" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </WrapPanel>

</Page>
