<Page
    x:Class="Aquila.Views.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Style="{StaticResource BasePageStyle}"
    Title="About"
    d:DataContext="{d:DesignInstance local:AboutPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <ui:Card Margin="0,0,0,8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="Aquila" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,2,0,10"
                               Opacity="0.65"
                               Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
                    <TextBlock Text="{Binding ViewModel.ProjectSummary, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="PROJECT" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="{Binding ViewModel.Maintainer, Mode=OneWay}"
                               Style="{StaticResource ChipName}" />
                    <TextBlock Margin="0,4,0,8"
                               Opacity="0.70"
                               Text="{Binding ViewModel.RepositoryUrl, Mode=OneWay}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Opacity="0.78"
                               Text="{Binding ViewModel.DependenciesSummary, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="SUPPORT &amp; CONTACT" Style="{StaticResource SectionLabel}" />
                    <TextBlock Margin="0,2,0,12"
                               Opacity="0.70"
                               Text="Aquila is free and open-source. If it's useful to you, consider supporting development. Questions or feedback are welcome."
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Command="{Binding ViewModel.OpenSupportCommand, Mode=OneWay}"
                                   Appearance="Primary" Padding="14,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Heart24" FontSize="15" Margin="0,0,7,0" />
                                <TextBlock Text="Support" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding ViewModel.OpenContactCommand, Mode=OneWay}"
                                   Appearance="Secondary" Padding="14,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Mail24" FontSize="15" Margin="0,0,7,0" />
                                <TextBlock Text="Contact" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding ViewModel.OpenRepositoryCommand, Mode=OneWay}"
                                   Appearance="Secondary" Padding="14,7">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Code24" FontSize="15" Margin="0,0,7,0" />
                                <TextBlock Text="GitHub" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="LICENSE" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="{Binding ViewModel.LicenseName, Mode=OneWay}"
                               Style="{StaticResource ChipName}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding ViewModel.LicenseSummary, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="16,14">
                <StackPanel>
                    <TextBlock Text="PRIVACY &amp; UPDATES" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="{Binding ViewModel.PrivacySummary, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
