<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:vm="clr-namespace:Aquila.ViewModels.Pages"
    xmlns:helpers="clr-namespace:Aquila.Helpers"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    mc:Ignorable="d">

    <Page.Resources>

        <helpers:ThroughputConverter x:Key="ThroughputConverter"/>
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <helpers:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
        <helpers:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
        <helpers:ThermalBrushConverter x:Key="ThermalBrushConverter"/>
        <helpers:FanMaxConverter x:Key="FanMaxConverter"/>

        <!-- ── Core bar DataTemplate ── -->
        <DataTemplate x:Key="CoreBarTemplate" DataType="{x:Type vm:CoreBarItem}">
            <StackPanel Margin="0,0">
                <TextBlock Text="{Binding Label}" FontSize="11" Opacity="0.45"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4" Height="120" Margin="6,0"
                        HorizontalAlignment="Stretch">
                    <Border VerticalAlignment="Bottom" CornerRadius="4"
                            Background="{DynamicResource Aquila.Cpu}" Opacity="0.85"
                            Height="{Binding BarHeight}"
                            HorizontalAlignment="Stretch"/>
                </Border>
                <TextBlock Text="{Binding ValueText}" FontSize="10" Opacity="0.50"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── GPU card DataTemplate (GPU1 and GPU2 share this) ── -->
        <DataTemplate x:Key="GpuCardTemplate" DataType="{x:Type vm:GpuCardData}">
            <ui:Card Margin="0,0,0,8" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="GPU" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource ChipName}" Margin="0,0,0,12"/>

                    <!-- 4 stat boxes -->
                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}">
                                    <Run Text="{Binding LoadSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{Binding TempSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                    <Run Text="{Binding TempSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{DynamicResource Aquila.Gpu}">
                                    <Run Text="{Binding ClockSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Clock" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatBoxValue}"
                                           Foreground="{DynamicResource Aquila.Power}">
                                    <Run Text="{Binding PowerSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                    <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- VRAM -->
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock Text="VRAM" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontSize="20" FontWeight="Normal"
                                       Foreground="{DynamicResource Aquila.Gpu}"
                                       Text="{Binding VramUsedSensor.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                            <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="/ {0:F0} {1}" FallbackValue="/ -- ">
                                        <Binding Path="VramTotalSensor.Value"/>
                                        <Binding Path="VramUsedSensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <ProgressBar Style="{StaticResource GpuBar}" Height="8"
                                     Value="{Binding VramPercent, Mode=OneWay, FallbackValue=0}"
                                     Maximum="100"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="10" Opacity="0.40"
                                       Text="{Binding VramUsedSensor.Value, StringFormat='{}{0:F1} used', FallbackValue='used'}"/>
                            <TextBlock Grid.Column="1" FontSize="10" Opacity="0.40">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1} total" FallbackValue="total">
                                        <Binding Path="VramTotalSensor.Value"/>
                                        <Binding Path="VramUsedSensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Opacity="0.14" Margin="0,10"/>

                    <!-- Fans -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                        <Binding Path="Fan1Sensor.Value"/>
                                        <Binding Path="Fan1Sensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                        <Binding Path="Fan2Sensor.Value"/>
                                        <Binding Path="Fan2Sensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </DataTemplate>

    </Page.Resources>

    <!-- ════════════════════════════════════════════════════════════════
         3-COLUMN GRID
         Col 0  (2*) — CPU + GPU(s)
         Col 1  (1.3*) — RAM + Network
         Col 2  (1.3*) — Power + Temperatures + Fans
         ════════════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="18,6,18,18">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 COL 0 — CPU card  +  GPU card(s) below
                 ══════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- CPU card -->
                <ui:Card Margin="0,0,0,8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.CpuName, FallbackValue='Processor'}"
                                   Style="{StaticResource ChipName}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ViewModel.CpuSummary}"
                                   FontSize="11" Opacity="0.45" Margin="0,0,0,12"
                                   Visibility="{Binding ViewModel.CpuSummary, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <!-- 4 stat boxes -->
                        <UniformGrid Columns="4" Margin="0,0,0,14">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding ViewModel.CpuGaugeValue, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding ViewModel.CpuTemperatureSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding ViewModel.CpuTemperatureSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Cpu}">
                                        <Run Text="{Binding ViewModel.EffectiveCpuClock, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Eff. Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Power}">
                                        <Run Text="{Binding ViewModel.CpuEnergySensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Per-core bar chart — WrapPanel fills available width -->
                        <TextBlock Text="CORE LOAD" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.CpuCoreItems}"
                                      ItemTemplate="{StaticResource CoreBarTemplate}"
                                      Margin="0,0,0,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- CPU sparkline -->
                        <TextBlock Text="USAGE — 60s" Style="{StaticResource SectionLabel}" Margin="0,0,0,2"/>
                        <lvc:CartesianChart
                            Height="64"
                            Series="{Binding ViewModel.CpuHistorySeries}"
                            XAxes="{Binding ViewModel.SparklineXAxes}"
                            YAxes="{Binding ViewModel.CpuHistoryYAxes}"
                            TooltipPosition="Hidden"
                            LegendPosition="Hidden"
                            ZoomMode="None"
                            Background="Transparent"/>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- CPU fans -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.CpuFanSpeed1Sensor.Value"/>
                                            <Binding Path="ViewModel.CpuFanSpeed1Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.CpuFanSpeed2Sensor.Value"/>
                                            <Binding Path="ViewModel.CpuFanSpeed2Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- GPU cards — explicit Gpu1 and Gpu2 so sparkline can bind to ViewModel -->
                <ui:Card Margin="0,0,0,8" Padding="16,14"
                         Visibility="{Binding ViewModel.Gpu1, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Gpu1.Name}" Style="{StaticResource ChipName}" Margin="0,0,0,12"/>

                        <UniformGrid Columns="4" Margin="0,0,0,14">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding ViewModel.Gpu1.LoadSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding ViewModel.Gpu1.TempSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding ViewModel.Gpu1.TempSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Gpu}">
                                        <Run Text="{Binding ViewModel.Gpu1.ClockSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Power}">
                                        <Run Text="{Binding ViewModel.Gpu1.PowerSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- VRAM -->
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="VRAM" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="20" FontWeight="Normal"
                                           Foreground="{DynamicResource Aquila.Gpu}"
                                           Text="{Binding ViewModel.Gpu1.VramUsedSensor.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                                <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="/ {0:F0} {1}" FallbackValue="">
                                            <Binding Path="ViewModel.Gpu1.VramTotalSensor.Value"/>
                                            <Binding Path="ViewModel.Gpu1.VramUsedSensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <ProgressBar Style="{StaticResource GpuBar}" Height="8"
                                         Value="{Binding ViewModel.Gpu1.VramPercent, Mode=OneWay, FallbackValue=0}"
                                         Maximum="100"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="10" Opacity="0.40"
                                           Text="{Binding ViewModel.Gpu1.VramUsedSensor.Value, StringFormat='{}{0:F1} used', FallbackValue='used'}"/>
                                <TextBlock Grid.Column="1" FontSize="10" Opacity="0.40">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1} total" FallbackValue="total">
                                            <Binding Path="ViewModel.Gpu1.VramTotalSensor.Value"/>
                                            <Binding Path="ViewModel.Gpu1.VramUsedSensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <Border Style="{StaticResource Divider}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Gpu1.Fan1Sensor.Value"/>
                                            <Binding Path="ViewModel.Gpu1.Fan1Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Gpu1.Fan2Sensor.Value"/>
                                            <Binding Path="ViewModel.Gpu1.Fan2Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- GPU 2 -->
                <ui:Card Margin="0,0,0,8" Padding="16,14"
                         Visibility="{Binding ViewModel.Gpu2, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.Gpu2.Name}" Style="{StaticResource ChipName}" Margin="0,0,0,12"/>

                        <UniformGrid Columns="4" Margin="0,0,0,14">
                            <Border Style="{StaticResource StatBox}" Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}">
                                        <Run Text="{Binding ViewModel.Gpu2.LoadSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="%" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Usage" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{Binding ViewModel.Gpu2.TempSensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                        <Run Text="{Binding ViewModel.Gpu2.TempSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="°C" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Temp" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Gpu}">
                                        <Run Text="{Binding ViewModel.Gpu2.ClockSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="MHz" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Clock" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatBox}" Margin="3,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StatBoxValue}"
                                               Foreground="{DynamicResource Aquila.Power}">
                                        <Run Text="{Binding ViewModel.Gpu2.PowerSensor.Value, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="W" FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Power" Style="{StaticResource StatBoxLabel}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- VRAM -->
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="VRAM" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="20" FontWeight="Normal"
                                           Foreground="{DynamicResource Aquila.Gpu}"
                                           Text="{Binding ViewModel.Gpu2.VramUsedSensor.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                                <TextBlock FontSize="11" VerticalAlignment="Bottom" Margin="3,0,0,3"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="/ {0:F0} {1}" FallbackValue="">
                                            <Binding Path="ViewModel.Gpu2.VramTotalSensor.Value"/>
                                            <Binding Path="ViewModel.Gpu2.VramUsedSensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <ProgressBar Style="{StaticResource GpuBar}" Height="8"
                                         Value="{Binding ViewModel.Gpu2.VramPercent, Mode=OneWay, FallbackValue=0}"
                                         Maximum="100"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="10" Opacity="0.40"
                                           Text="{Binding ViewModel.Gpu2.VramUsedSensor.Value, StringFormat='{}{0:F1} used', FallbackValue='used'}"/>
                                <TextBlock Grid.Column="1" FontSize="10" Opacity="0.40">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1} total" FallbackValue="total">
                                            <Binding Path="ViewModel.Gpu2.VramTotalSensor.Value"/>
                                            <Binding Path="ViewModel.Gpu2.VramUsedSensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <Border Style="{StaticResource Divider}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fan 1" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Gpu2.Fan1Sensor.Value"/>
                                            <Binding Path="ViewModel.Gpu2.Fan1Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Fan 2" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                            <Binding Path="ViewModel.Gpu2.Fan2Sensor.Value"/>
                                            <Binding Path="ViewModel.Gpu2.Fan2Sensor.Unit"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

            </StackPanel>

            <!-- ══════════════════════════════════════════════════════════
                 COL 1 — RAM + Network
                 ══════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Column="1" Margin="4,0,8,0">

                <!-- RAM card -->
                <ui:Card Margin="0,0,0,8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="MEMÓRIA RAM" Style="{StaticResource SectionLabel}"/>

                        <!-- Big used value -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock FontSize="36" FontWeight="Light"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="{Binding ViewModel.MemoryUsedSensor.Value, StringFormat='{}{0:F1}', FallbackValue='--'}"/>
                            <TextBlock Text="GB" FontSize="14" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="2,0,0,7"/>
                        </StackPanel>

                        <!-- de X GB -->
                        <TextBlock FontSize="12" Opacity="0.60" Margin="0,0,0,10">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="de {0:F0} GB total" FallbackValue="--">
                                    <Binding Path="ViewModel.RamTotalGb"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Segmented bar: Used / Cache / Free -->
                        <Grid Height="8" Margin="0,10,0,6" x:Name="RamBar">
                            <Border CornerRadius="4" Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            <DockPanel>
                                <!-- Used (blue) -->
                                <Border DockPanel.Dock="Left"
                                        Background="{DynamicResource Aquila.Cpu}"
                                        CornerRadius="4,0,0,4">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.RamGaugeValue"/>
                                            <Binding Source="0"/>
                                            <Binding Source="100"/>
                                            <Binding ElementName="RamBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <!-- Cache (green) -->
                                <Border DockPanel.Dock="Left"
                                        Background="{DynamicResource Aquila.Ram}"
                                        Opacity="0.8">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                            <Binding Path="ViewModel.CacheBarWeight"/>
                                            <Binding Source="0"/>
                                            <Binding Source="100"/>
                                            <Binding ElementName="RamBar" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <!-- Gap for free space -->
                            </DockPanel>
                        </Grid>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <!-- Used -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource Aquila.Cpu}"/>
                            <TextBlock FontSize="11" Opacity="0.65" Margin="0,0,12,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Usada {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.MemoryUsedSensor.Value"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            
                            <!-- Cache -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource Aquila.Ram}"/>
                            <TextBlock FontSize="11" Opacity="0.65" Margin="0,0,12,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Cache {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.CacheGb"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            
                            <!-- Free -->
                            <Border Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Background="{DynamicResource TextFillColorTertiaryBrush}" Opacity="0.3"/>
                            <TextBlock FontSize="11" Opacity="0.65">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Livre {0:F1}" FallbackValue="--">
                                        <Binding Path="ViewModel.MemoryAvailableSensor.Value"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <Border Style="{StaticResource Divider}"/>

                        <!-- Page reads / writes StatBoxes -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Leitura -->
                            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Page Reads" FontSize="10" Opacity="0.55" Margin="0,0,0,3"/>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Aquila.Cpu}">
                                        <Run Text="{Binding ViewModel.PageReadsPerSec, Mode=OneWay, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="/s" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Escrita -->
                            <Border Grid.Column="1" Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="6" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Page Writes" FontSize="10" Opacity="0.55" Margin="0,0,0,3"/>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Aquila.Ram}">
                                        <Run Text="{Binding ViewModel.PageWritesPerSec, Mode=OneWay, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                                        <Run Text="/s" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Network card -->
                <ui:Card Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="NETWORK" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding ViewModel.NetworkName, FallbackValue='Adapter'}"
                                   FontSize="12" FontWeight="Normal" Opacity="0.55"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↓ Download" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Cpu}"
                                       Text="{Binding ViewModel.NetworkDownloadSpeedSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <ProgressBar Style="{StaticResource CpuBar}" Margin="0,2,0,8"
                                     Value="{Binding ViewModel.NetworkDownloadSpeedSensor.Value, FallbackValue=0}"
                                     Maximum="125000000"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↑ Upload" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Aquila.Ram}"
                                       Text="{Binding ViewModel.NetworkUploadSpeedSensor.Value, Converter={StaticResource ThroughputConverter}, FallbackValue='--'}"/>
                        </Grid>
                        <ProgressBar Style="{StaticResource RamBar}" Margin="0,2,0,0"
                                     Value="{Binding ViewModel.NetworkUploadSpeedSensor.Value, FallbackValue=0}"
                                     Maximum="125000000"/>

                        <Border Style="{StaticResource Divider}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Received" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.NetworkDataDownloadedSensor.Value"/>
                                        <Binding Path="ViewModel.NetworkDataDownloadedSensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sent" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource RowValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} {1}" FallbackValue="--">
                                        <Binding Path="ViewModel.NetworkDataUploadedSensor.Value"/>
                                        <Binding Path="ViewModel.NetworkDataUploadedSensor.Unit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

            </StackPanel>

            <!-- ══════════════════════════════════════════════════════════
                 COL 2 — Power + Temperatures + Fans
                 ══════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Column="2" Margin="4,0,0,0">

                <!-- Power card -->
                <ui:Card Margin="0,0,0,8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="POWER" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock FontSize="34"
                                       Text="{Binding ViewModel.TotalPower, StringFormat='{}{0:F0}', FallbackValue='--'}"/>
                            <TextBlock Text="W total" FontSize="13" VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="5,0,0,6"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource CpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.CpuEnergySensor.Value, FallbackValue=0}"
                                         Maximum="250"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.CpuEnergySensor.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource GpuBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.Gpu1.PowerSensor.Value, FallbackValue=0}"
                                         Maximum="450"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.Gpu1.PowerSensor.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RAM" Style="{StaticResource RowLabel}"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource RamBar}" VerticalAlignment="Center"
                                         Value="{Binding ViewModel.MemoryPowerSensor.Value, FallbackValue=0}"
                                         Maximum="30"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12"
                                       Text="{Binding ViewModel.MemoryPowerSensor.Value, StringFormat='{}{0:F0}W', FallbackValue='--'}"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Temperatures card -->
                <ui:Card Margin="0,0,0,8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="TEMPERATURES" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.SystemTemperatures}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       Style="{StaticResource RowLabel}"/>
                                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{Binding Sensor.Value, Converter={StaticResource ThermalBrushConverter}}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                        <Binding Path="Sensor.Value"/>
                                                        <Binding Path="Sensor.Unit"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource ThinBar}"
                                                     Value="{Binding Sensor.Value, FallbackValue=0}"
                                                     Maximum="110"
                                                     Foreground="{Binding Sensor.Value, Converter={StaticResource ThermalBrushConverter}}"
                                                     Margin="0,3,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Fans card -->
                <ui:Card Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="FANS" Style="{StaticResource SectionLabel}"/>
                        <ItemsControl ItemsSource="{Binding ViewModel.SystemFans}">
                             <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding Value, Converter={StaticResource ZeroToCollapsedConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Style="{StaticResource RowLabel}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Grid.Column="1" Style="{StaticResource FanBar}"
                                                     VerticalAlignment="Center"
                                                     Value="{Binding Value, FallbackValue=0}"
                                                     Maximum="{Binding Max, Converter={StaticResource FanMaxConverter}}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource RowValue}" FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0} {1}" FallbackValue="--">
                                                    <Binding Path="Value"/>
                                                    <Binding Path="Unit"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </Grid>
    </ScrollViewer>

</Page>
