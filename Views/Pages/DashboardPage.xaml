<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="98*"/>
            <RowDefinition Height="47*"/>
        </Grid.RowDefinitions>
        <ItemsControl ItemsSource="{Binding ViewModel.Computer.HardwareList}" Margin="15">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Usamos o ui:Card para ter o aspeto de widget -->
                    <ui:Card Margin="10,0,0,15">
                        <StackPanel>
                            <!-- O Título do Cartão é o nome do Hardware -->
                            <TextBlock Text="{Binding Name}" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Margin="12" />

                            <!-- A ListView para os sensores deste hardware -->
                            <ui:ListView ItemsSource="{Binding Sensors}" 
                                     Background="Transparent" 
                                     BorderThickness="0"
                                     Margin="12,-6,12,12">
                                <ui:ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>

                                        <GridViewColumn DisplayMemberBinding="{Binding Name}" Width="250"/>
                                        <GridViewColumn Width="100">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock HorizontalAlignment="Right">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:F1} {1}">
                                                                <Binding Path="Value" />
                                                                <Binding Path="Unit" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn DisplayMemberBinding="{Binding Identifier}" Width="350"/>
                                    </GridView>
                                </ui:ListView.View>
                            </ui:ListView>
                        </StackPanel>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>

</Page>
