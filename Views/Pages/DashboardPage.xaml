<Page
    x:Class="Aquila.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Aquila.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Style="{StaticResource BasePageStyle}"
    Title="DashboardPage"
    d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <WrapPanel Margin="10">
        <ui:Card>
            <StackPanel>
                <TextBlock Text="{Binding ViewModel.CpuName}" FontWeight="Bold" />
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU Temperature" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Margin="12,-6,12,12">
                    <ui:SymbolIcon Symbol="Temperature24" Width="24" Margin="0,0,0,5"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}" FallbackValue="-- °C">
                                <Binding Path="ViewModel.CpuTemperatureSensor.Value" />
                                <Binding Path="ViewModel.CpuTemperatureSensor.Unit" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ui:Card>
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU Usage" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Margin="12,-6,12,12">
                    <ui:SymbolIcon Symbol="TopSpeed24" Width="24" Margin="0,0,0,5"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}" FallbackValue="-- %">
                                <Binding Path="ViewModel.CpuUsageSensor.Value" />
                                <Binding Path="ViewModel.CpuUsageSensor.Unit" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ui:Card>
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU Fan Speed 1" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Margin="12,-6,12,12">
                    <ui:SymbolIcon Symbol="DataUsage24" Width="24" Margin="0,0,0,5"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}" FallbackValue="-- RPM">
                                <Binding Path="ViewModel.CpuFanSpeed1Sensor.Value" />
                                <Binding Path="ViewModel.CpuFanSpeed1Sensor.Unit" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ui:Card>
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU Fan Speed 2" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Margin="12,-6,12,12">
                    <ui:SymbolIcon Symbol="DataUsage24" Width="24" Margin="0,0,0,5"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}" FallbackValue="-- RPM">
                                <Binding Path="ViewModel.CpuFanSpeed1Sensor.Value" />
                                <Binding Path="ViewModel.CpuFanSpeed1Sensor.Unit" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ui:Card>
        <ui:Card Width="220" Margin="5">
            <StackPanel>
                <TextBlock Text="CPU Power Usage" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Margin="12,-6,12,12">
                    <ui:SymbolIcon Symbol="Alert24" Width="24" Margin="0,0,0,5"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0}{1}" FallbackValue="-- RPM">
                                <Binding Path="ViewModel.CpuEnergySensor.Value" />
                                <Binding Path="ViewModel.CpuEnergySensor.Unit" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ui:Card>
            </StackPanel>
        </ui:Card>
    </WrapPanel>

</Page>
