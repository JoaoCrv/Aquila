<Page x:Class="Aquila.Views.Pages.ExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Aquila.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Explorer"
      Style="{StaticResource BasePageStyle}"
    >

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding ViewModel.Hardware}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ui:ListView ItemsSource="{Binding Sensors.Values}" Background="Transparent" BorderThickness="0">
                            <ui:ListView.View>
                                <ui:GridView>
                                    <ui:GridViewColumn Header="Sensor Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                                    
                                    
                                    <ui:GridViewColumn Header="Value" Width="100">
                                        <ui:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Right">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:F1} {1}">
                                                            <Binding Path="Value"/>
                                                            <Binding Path="Unit"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ui:GridViewColumn.CellTemplate>
                                    </ui:GridViewColumn>

                                    <GridViewColumn Header="Identifier" DisplayMemberBinding="{Binding Identifier}" Width="350"/>
                                </ui:GridView>
                            </ui:ListView.View>
                        </ui:ListView>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Page>
